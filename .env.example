# =============================================================================
# Vantage — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# .env is listed in .gitignore and must NEVER be committed to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM Provider (required)
# -----------------------------------------------------------------------------
# OpenAI API key — used by all agents for structured output generation.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here


# -----------------------------------------------------------------------------
# Finnhub (optional)
# -----------------------------------------------------------------------------
# Used by the News Analyst Agent as the primary news source.
# Falls back to yfinance + Yahoo Finance RSS if not set.
# Free tier: 60 calls/min. Register at: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here


# -----------------------------------------------------------------------------
# FRED — Federal Reserve Economic Data (optional)
# -----------------------------------------------------------------------------
# Used by the Macro / Sector Analyst Agent for CPI, Fed Funds Rate,
# unemployment, GDP, and PCE data.
# Silently skipped if not set — no errors will be raised.
# Free registration at: https://fred.stlouisfed.org/docs/api/fred/
FRED_API_KEY=your_fred_api_key_here


# =============================================================================
# Agent Configuration Overrides (optional)
# =============================================================================
# All values below are optional. If not set, defaults from config/settings.py
# are used. Uncomment and edit only the ones you want to override.
# =============================================================================


# -----------------------------------------------------------------------------
# Market Analyst Agent
# -----------------------------------------------------------------------------
# MARKET_PERIOD=1y           # yfinance history period: 1d, 5d, 1mo, 3mo, 6mo, 1y, 2y, 5y
# MARKET_INTERVAL=1d         # yfinance candle interval: 1m, 5m, 15m, 1h, 1d, 1wk
# MARKET_RECENT_SESSIONS=10  # Number of recent OHLCV sessions to include in context
# MARKET_GAP_THRESHOLD=0.02  # Minimum gap size to report (e.g. 0.02 = 2%)
# MARKET_VOLUME_SPIKE_MULT=2.0  # Volume multiple above 20d avg to flag as a spike


# -----------------------------------------------------------------------------
# Fundamentals Analyst Agent
# -----------------------------------------------------------------------------
# FUNDAMENTALS_QUARTERS=12         # Quarters of income/cashflow/balance sheet history
# FUNDAMENTALS_EARNINGS_QUARTERS=12  # Quarters of EPS surprise history


# -----------------------------------------------------------------------------
# News Analyst Agent
# -----------------------------------------------------------------------------
# NEWS_FINNHUB_CALLS_PER_MIN=60  # Finnhub rate limit (calls per minute)
# NEWS_MAX_ARTICLES=15           # Maximum articles to pass to the LLM
# NEWS_MAX_AGE_DAYS=7            # Discard articles older than this many days


# -----------------------------------------------------------------------------
# Sentiment Analyst Agent
# -----------------------------------------------------------------------------
# SENTIMENT_STOCKTWITS_LIMIT=30                  # Max StockTwits messages to fetch
# SENTIMENT_REDDIT_SUBREDDITS=stocks,investing,wallstreetbets,options  # Comma-separated
# SENTIMENT_REDDIT_POSTS_PER_SUB=10              # Posts per subreddit
# SENTIMENT_REDDIT_TIME_FILTER=week              # Reddit time filter: hour, day, week, month
# SENTIMENT_MAX_AGE_HOURS=48                     # Discard posts older than this many hours


# -----------------------------------------------------------------------------
# Options Strategist Agent
# -----------------------------------------------------------------------------
# OPTIONS_EXPIRATIONS_FOR_PCR=8   # Number of expirations to include in P/C ratio
# OPTIONS_OI_TABLE_ROWS=10        # Rows in the OI distribution table
# OPTIONS_TOP_WALLS=5             # Number of top call/put OI walls to report
# OPTIONS_MEDIUM_DTE_TARGET=30    # Target DTE for the medium-term expiry analysis


# -----------------------------------------------------------------------------
# Macro / Sector Analyst Agent
# -----------------------------------------------------------------------------
# MACRO_FRED_CALLS_PER_MIN=120   # FRED API rate limit (calls per minute)
# MACRO_NEWS_MAX_AGE_DAYS=7      # Max age of sector news articles
# MACRO_NEWS_MAX_ARTICLES=10     # Max sector news articles to include
# MACRO_HISTORY_PERIOD=3mo       # Sector ETF history period for trend analysis


# -----------------------------------------------------------------------------
# Compliance Agent
# -----------------------------------------------------------------------------
# COMPLIANCE_INSIDER_LOOKBACK_DAYS=180   # Days of insider transaction history
# COMPLIANCE_TOP_HOLDERS=10              # Number of top institutional holders to show
# COMPLIANCE_ANALYST_CHANGES=5          # Number of recent analyst rating changes
# COMPLIANCE_EDGAR_FILINGS=5            # Number of recent SEC 8-K filings to retrieve
# COMPLIANCE_NEWS_MAX_AGE_DAYS=30       # Max age of compliance-relevant news
# COMPLIANCE_NEWS_MAX_ARTICLES=15       # Max compliance news articles
# COMPLIANCE_BLACKOUT_WINDOW_DAYS=14    # Days before earnings to flag as blackout window
