# =============================================================================
# Vantage — .gitignore
# =============================================================================

# Environment variables — NEVER commit this file
.env

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Output reports (generated at runtime)
outputs/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Logs
*.log
